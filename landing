<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Clarity — Tu sistema de gestión personal</title>
  <meta name="description" content="Tu sistema de gestión personal. Cada tarea te acerca a tus metas."/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&family=Lora:ital,wght@0,400;1,400&display=swap" rel="stylesheet"/>
  <style>
    *{box-sizing:border-box;margin:0;padding:0;}
    html{scroll-behavior:smooth;}
    body{
      font-family:'DM Sans',sans-serif;
      background:#F5F2EE;
      color:#2C2825;
      min-height:100vh;
      -webkit-font-smoothing:antialiased;
    }

    /* ── Layout ── */
    .shell{
      max-width:560px;
      margin:0 auto;
      padding:0 28px;
      min-height:100vh;
      display:flex;
      flex-direction:column;
      justify-content:center;
      padding-top:80px;
      padding-bottom:80px;
    }

    /* ── Nav ── */
    .nav{
      position:fixed;
      top:0;left:0;right:0;
      padding:24px 32px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      background:rgba(245,242,238,.92);
      backdrop-filter:blur(12px);
      -webkit-backdrop-filter:blur(12px);
      z-index:100;
      border-bottom:1px solid rgba(0,0,0,.04);
    }
    .nav-logo{
      font-size:10px;
      letter-spacing:.22em;
      text-transform:uppercase;
      color:#9B8878;
      font-weight:500;
    }
    .nav-badge{
      font-size:10px;
      color:#B0AA9F;
      background:white;
      border:1px solid #EAE6E0;
      border-radius:99px;
      padding:4px 12px;
    }

    /* ── Hero ── */
    .tree{
      font-size:40px;
      margin-bottom:32px;
      display:block;
      animation:gentleFloat 4s ease-in-out infinite;
    }
    @keyframes gentleFloat{
      0%,100%{transform:translateY(0);}
      50%{transform:translateY(-6px);}
    }

    .tag{
      display:inline-flex;
      align-items:center;
      gap:6px;
      font-size:10px;
      font-weight:500;
      letter-spacing:.12em;
      text-transform:uppercase;
      color:#9B8878;
      margin-bottom:20px;
    }
    .tag-dot{
      width:6px;height:6px;
      border-radius:50%;
      background:#9B8878;
    }

    .headline{
      font-family:'DM Sans',sans-serif;
      font-size:clamp(30px, 5vw, 42px);
      font-weight:300;
      line-height:1.15;
      letter-spacing:-.03em;
      color:#2C2825;
      margin-bottom:20px;
    }
    .headline em{
      font-family:'Lora',serif;
      font-style:italic;
      font-weight:400;
    }

    .subline{
      font-size:16px;
      font-weight:300;
      color:#9B8878;
      line-height:1.7;
      margin-bottom:48px;
      max-width:420px;
    }

    /* ── Features ── */
    .features{
      display:flex;
      flex-direction:column;
      gap:16px;
      margin-bottom:52px;
    }
    .feature{
      display:flex;
      align-items:flex-start;
      gap:14px;
    }
    .feature-dot{
      width:6px;height:6px;
      border-radius:50%;
      background:#C4B5A5;
      flex-shrink:0;
      margin-top:8px;
    }
    .feature-text{
      font-size:14px;
      color:#6B6258;
      line-height:1.6;
    }
    .feature-text strong{
      color:#2C2825;
      font-weight:500;
    }

    /* ── Form ── */
    .form-label{
      font-size:11px;
      font-weight:500;
      letter-spacing:.1em;
      text-transform:uppercase;
      color:#B0AA9F;
      margin-bottom:12px;
      display:block;
    }
    .form-row{
      display:flex;
      gap:10px;
      margin-bottom:14px;
    }
    .email-input{
      flex:1;
      padding:14px 18px;
      border-radius:12px;
      border:1px solid #E5E1DB;
      background:white;
      font-family:'DM Sans';
      font-size:14px;
      color:#2C2825;
      outline:none;
      transition:border-color .2s, box-shadow .2s;
    }
    .email-input::placeholder{color:#C8C3BB;}
    .email-input:focus{
      border-color:#9B8878;
      box-shadow:0 0 0 3px rgba(155,136,120,.1);
    }
    .submit-btn{
      padding:14px 24px;
      border-radius:12px;
      border:none;
      background:#2C2825;
      color:white;
      font-family:'DM Sans';
      font-size:14px;
      font-weight:500;
      cursor:pointer;
      white-space:nowrap;
      transition:opacity .2s, transform .1s;
    }
    .submit-btn:hover{opacity:.88;}
    .submit-btn:active{transform:scale(.97);}
    .submit-btn:disabled{opacity:.5;cursor:not-allowed;}

    .form-hint{
      font-size:11px;
      color:#C8C3BB;
      line-height:1.6;
    }

    /* ── Success state ── */
    .success{
      display:none;
      background:white;
      border:1px solid #EAE6E0;
      border-radius:14px;
      padding:20px 24px;
      margin-bottom:14px;
    }
    .success.visible{display:block;}
    .success-title{
      font-size:14px;
      font-weight:500;
      color:#2C2825;
      margin-bottom:4px;
    }
    .success-sub{
      font-size:13px;
      color:#B0AA9F;
      line-height:1.6;
    }

    /* ── Divider ── */
    .divider{
      height:1px;
      background:linear-gradient(to right, transparent, #EAE6E0, transparent);
      margin:52px 0;
    }

    /* ── Levels preview ── */
    .levels-title{
      font-size:12px;
      font-weight:500;
      letter-spacing:.1em;
      text-transform:uppercase;
      color:#B0AA9F;
      margin-bottom:20px;
    }
    .levels{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
    }
    .level{
      display:flex;
      align-items:center;
      gap:6px;
      background:white;
      border:1px solid #EAE6E0;
      border-radius:99px;
      padding:6px 14px;
    }
    .level-icon{font-size:13px;}
    .level-name{font-size:11px;color:#9B8878;}

    /* ── Footer ── */
    .footer{
      margin-top:64px;
      padding-top:32px;
      border-top:1px solid #EAE6E0;
      display:flex;
      align-items:center;
      justify-content:space-between;
    }
    .footer-logo{
      font-size:9px;
      letter-spacing:.2em;
      text-transform:uppercase;
      color:#C8C3BB;
    }
    .footer-copy{
      font-size:11px;
      color:#D5CFC8;
    }

    /* ── Animations ── */
    @keyframes fadeUp{
      from{opacity:0;transform:translateY(16px);}
      to{opacity:1;transform:translateY(0);}
    }
    .fade-1{animation:fadeUp .5s ease .1s both;}
    .fade-2{animation:fadeUp .5s ease .2s both;}
    .fade-3{animation:fadeUp .5s ease .3s both;}
    .fade-4{animation:fadeUp .5s ease .4s both;}
    .fade-5{animation:fadeUp .5s ease .5s both;}
    .fade-6{animation:fadeUp .5s ease .6s both;}

    @media(max-width:480px){
      .form-row{flex-direction:column;}
      .submit-btn{width:100%;}
      .nav{padding:20px 24px;}
    }
  </style>
</head>
<body>

  <!-- Nav -->
  <nav class="nav">
    <span class="nav-logo">Clarity</span>
    <span class="nav-badge">Beta privada · Cupos limitados</span>
  </nav>

  <!-- Main -->
  <div class="shell">

    <span class="tree fade-1">🌱</span>

    <div class="tag fade-1">
      <div class="tag-dot"></div>
      Sistema de gestión personal
    </div>

    <h1 class="headline fade-2">
      Tu sistema de<br/>
      gestión personal.<br/>
      <em>Cada tarea te acerca<br/>a la vida que vos querés.</em>
    </h1>

    <p class="subline fade-3">
      Clarity conecta tus metas de vida con tus proyectos y tus tareas del día a día. No es una lista de pendientes — es una arquitectura de vida.
    </p>

    <div class="features fade-3">
      <div class="feature">
        <div class="feature-dot"></div>
        <div class="feature-text"><strong>Metas → Proyectos → Tareas.</strong> Todo conectado. Cada acción contribuye a algo más grande.</div>
      </div>
      <div class="feature">
        <div class="feature-dot"></div>
        <div class="feature-text"><strong>Indicadores que te dicen la verdad.</strong> Alineación estratégica, carga cognitiva, tasa de postergación.</div>
      </div>
      <div class="feature">
        <div class="feature-dot"></div>
        <div class="feature-text"><strong>El Cerezo.</strong> Cada tarea completada hace crecer tu árbol. Desde Semilla hasta Jindai Zakura — el cerezo más antiguo del mundo. Porque tus metas dependen de tu carácter y tu constancia.</div>
      </div>
    </div>

    <!-- Form -->
    <div class="fade-4">
      <span class="form-label">Sumate a la lista de espera</span>

      <div class="success" id="success">
        <div class="success-title">🌱 Ya estás en la lista</div>
        <div class="success-sub">Te vamos a avisar cuando haya un lugar disponible. Gracias por tu interés en Clarity.</div>
      </div>

      <div class="form-row" id="form-row">
        <input
          class="email-input"
          type="email"
          id="email"
          placeholder="tu@email.com"
          autocomplete="email"
        />
        <button class="submit-btn" id="submit-btn" onclick="submitWaitlist()">
          Anotarme
        </button>
      </div>
      <p class="form-hint">Sin spam. Te avisamos cuando haya lugar. Eso es todo.</p>
    </div>

    <div class="divider fade-5"></div>

    <!-- Levels preview -->
    <div class="fade-5">
      <div class="levels-title">Tu árbol crece con cada tarea</div>
      <div class="levels">
        <div class="level"><span class="level-icon">🌱</span><span class="level-name">Semilla</span></div>
        <div class="level"><span class="level-icon">🌿</span><span class="level-name">Brote</span></div>
        <div class="level"><span class="level-icon">🪴</span><span class="level-name">Retoño</span></div>
        <div class="level"><span class="level-icon">🌸</span><span class="level-name">En Flor</span></div>
        <div class="level"><span class="level-icon">🌳</span><span class="level-name">Maduro</span></div>
        <div class="level"><span class="level-icon">🎋</span><span class="level-name">Mayor</span></div>
        <div class="level"><span class="level-icon">✨</span><span class="level-name">Jindai Zakura</span></div>
      </div>
    </div>

    <!-- Footer -->
    <div class="footer fade-6">
      <span class="footer-logo">Clarity</span>
      <span class="footer-copy">© 2026 · Todos los derechos reservados</span>
    </div>

  </div>

  <script>
    const SUPABASE_URL = 'https://wdncosdqufitaxddnrfm.supabase.co';
    const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6IndkbmNvc2RxdWZpdGF4ZGRucmZtIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY4MzE0OTUsImV4cCI6MjA5MjQwNzQ5NX0.HndgrvPhhV8Ty13ieyfJwgsM80erG6mPufHGV90jT10';

    async function submitWaitlist() {
      const email = document.getElementById('email').value.trim();
      if (!email || !email.includes('@')) {
        document.getElementById('email').focus();
        return;
      }

      const btn = document.getElementById('submit-btn');
      btn.disabled = true;
      btn.textContent = 'Guardando...';

      try {
        const res = await fetch(`${SUPABASE_URL}/rest/v1/waitlist`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'apikey': SUPABASE_KEY,
            'Authorization': `Bearer ${SUPABASE_KEY}`,
            'Prefer': 'return=minimal',
          },
          body: JSON.stringify({ email, created_at: new Date().toISOString() }),
        });

        if (res.ok || res.status === 409) {
          document.getElementById('form-row').style.display = 'none';
          document.getElementById('success').classList.add('visible');
        } else {
          throw new Error('Error');
        }
      } catch(e) {
        btn.disabled = false;
        btn.textContent = 'Anotarme';
        alert('Algo salió mal. Intentá de nuevo.');
      }
    }

    document.getElementById('email').addEventListener('keydown', e => {
      if (e.key === 'Enter') submitWaitlist();
    });
  </script>

</body>
</html>
